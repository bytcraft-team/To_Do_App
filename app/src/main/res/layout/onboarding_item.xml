<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="32dp"
    android:background="@android:color/white">

    <!-- Illustration -->
    <ImageView
        android:id="@+id/onboarding_image"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center_horizontal"
        android:scaleType="fitCenter"
        android:layout_marginTop="40dp"
        android:src="@drawable/task_manage"
        android:contentDescription="Onboarding illustration" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="40dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/onboarding_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage your tasks easily"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1F2937"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/onboarding_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create, organize and track your daily tasks in one place."
        android:textSize="16sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:lineSpacingMultiplier="1.6" />

</LinearLayout>